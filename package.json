	},
	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/bun": "latest",
		"typescript": "^5.5.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"fastify": "^5.8.5",
		"jose": "^6.2.3",
		"yaml": "^2.9.0"
	}
}
