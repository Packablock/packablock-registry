{
	"name": "packablock-registry",
	"module": "index.ts",
	"type": "module",
	"scripts": {
		"start": "bun run index.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format:check": "biome format .",
